# SaneMail runs as a local web app + local API talking to Ollama.
# Required: OLLAMA_HOST and OLLAMA_API_KEY (or a local Ollama at 127.0.0.1:11434).
# Required for Gmail sync: GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET.
# Everything else has sensible local defaults.

# --- Server ---
PORT=3000
HOST=127.0.0.1
APP_ORIGIN=http://localhost:3000
WEB_ORIGIN=http://localhost:5173
DATA_DIR=./data

# --- Storage ---
STORE_DRIVER=json
APP_SECRET=
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=local-v1
DATABASE_URL=

# --- Auth (Supabase) ---
# In production, SUPABASE_JWT_SECRET is required. Get it from
# Supabase project settings → API → JWT Secret.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated

# Dev-only bypass: when set in a non-production NODE_ENV, the API treats every
# unauthenticated request as this user. Useful for `curl` and for running the
# web app locally without standing up Supabase. Refused in production.
DEV_USER_ID=
DEV_USER_EMAIL=

# Web app (Vite-prefixed; embedded in the client bundle at build time).
# When VITE_SUPABASE_URL is empty, the web app skips the sign-in screen and
# trusts the backend's DEV_USER_ID bypass.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=sanemail
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SHADOW_DB=sanemail_shadow
POSTGRES_ROOT_DB=postgres
SHADOW_DATABASE_URL=
ROOT_DATABASE_URL=
QUEUE_DATABASE_URL=

# --- Queue / worker ---
QUEUE_DRIVER=local-json
QUEUE_WORKER_ENABLED=false
QUEUE_AUTO_POST_INGEST_JOBS=false
QUEUE_POLL_INTERVAL_MS=1000
CLASSIFICATION_BATCH_SIZE=10

# --- Connectors ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
SYNC_MESSAGE_LIMIT=50
SYNC_QUERY=newer_than:90d -in:chats

# --- LLM (Ollama, required) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=deepseek-v4-pro:cloud
OLLAMA_THINK=high
OLLAMA_TEMPERATURE=0
OLLAMA_API_KEY=

# Optional: use a faster model for per-message classification.
OLLAMA_CLASSIFICATION_MODEL=
OLLAMA_CLASSIFICATION_THINK=false
OLLAMA_CLASSIFICATION_TEMPERATURE=0

# --- AI loop tuning ---
AI_TIMEOUT_MS=120000
AI_MAX_RETRIES=3
AI_RUN_LIMIT=500
AI_BRIEFING_MODE=auto
AI_OLLAMA_CLASSIFY_MESSAGES=false

# --- Observability (optional Phoenix tracer) ---
PHOENIX_ENABLED=false
PHOENIX_PROJECT_NAME=Sanemail
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_BATCH=false
PHOENIX_ALLOW_SENSITIVE_CONTENT=false
OPENINFERENCE_HIDE_INPUTS=true
OPENINFERENCE_HIDE_INPUT_MESSAGES=true
OPENINFERENCE_HIDE_EMBEDDINGS_VECTORS=true
